{
  "name": "dpv-booking-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":     "vite dev --port 5180",
    "build":   "vite build",
    "preview": "vite build && wrangler pages dev .svelte-kit/cloudflare --port 5181",
    "deploy":  "npm run build && wrangler pages deploy .svelte-kit/cloudflare"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin":      "^1.25.6",
    "@sveltejs/adapter-cloudflare": "^4.9.0",
    "@sveltejs/kit":                "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte":                       "^5.49.2",
    "vite":                         "^7.3.1",
    "wrangler":                     "^4.0.0"
  },
  "dependencies": {
    "flatpickr": "^4.6.13"
  }
}
